{
  "name": "fyp",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:client\" \"npm run dev:server\" --names \"client,server\" --prefix-colors \"blue,green\"",
    "dev:client": "vite",
    "dev:server": "tsx watch --env-file=.env src/server/index.ts",
    "vercel-build": "npm run build",
    "build": "tsc -b && vite build && tsc --project tsconfig.server.json",
    "build:client": "tsc -b && vite build",
    "build:server": "tsc --project tsconfig.server.json",
    "lint": "eslint .",
    "preview": "vite preview",
    "start": "NODE_ENV=production node dist/server/index.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:studio": "drizzle-kit studio",
    "db:seed-passwords": "tsx src/db/seed-passwords.ts"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.23",
    "@ai-sdk/openai": "^3.0.19",
    "@headlessui/react": "^2.2.9",
    "@heroicons/react": "^2.2.0",
    "@hono/node-server": "^1.19.9",
    "@supabase/supabase-js": "^2.91.1",
    "@tanstack/react-query": "^5.90.20",
    "@tanstack/react-router": "^1.156.0",
    "@tanstack/router-devtools": "^1.156.0",
    "@tanstack/router-plugin": "^1.156.0",
    "@types/bcryptjs": "^2.4.6",
    "@xyflow/react": "^12.10.0",
    "ai": "^6.0.50",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.2.3",
    "drizzle-kit": "^0.31.8",
    "drizzle-orm": "^0.45.1",
    "graphile-worker": "^0.16.6",
    "hono": "^4.11.5",
    "hono-rate-limiter": "^0.5.3",
    "jose": "^6.2.1",
    "plantuml-encoder": "^1.4.0",
    "postgres": "^3.4.8",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-markdown": "^10.1.0",
    "tsx": "^4.21.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@tailwindcss/postcss": "^4.1.18",
    "@types/node": "^24.10.9",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.23",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.18",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.2.4",
    "vitest": "^4.1.0"
  }
}
